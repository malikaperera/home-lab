# Copy to .env and fill in values. Never commit .env.

TZ=Australia/Melbourne

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=changeme

# Pi-hole admin UI password
PIHOLE_PASSWORD=changeme

# Alertmanager → Telegram
# Use your Roderick bot token and chat ID, or create a dedicated alerts bot
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Port map (defaults shown — change only if you have conflicts)
PROMETHEUS_PORT=9090
GRAFANA_PORT=3002
LOKI_PORT=3100
ALERTMANAGER_PORT=9093
CADVISOR_PORT=8082
NODE_EXPORTER_PORT=9100
UPTIME_KUMA_PORT=3003

# Ollama (host-level daemon on mini PC)
OLLAMA_HOST=http://host.docker.internal:11434
